# Local companion setup. The server uses safe local defaults for session signing,
# browser origins, OpenAI provider, model, HTTPS endpoint, and timeout.
OPENAI_API_KEY=replace-with-your-server-only-openai-key

# Optional OpenAI operator overrides.
# COMPANION_PROVIDER=openai
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_MS=12000
# COMPANION_PORT=8787

# Production requires explicit session and origin configuration. Generate a unique
# secret and set the exact TLS game origin(s) in the deployment environment.
# COMPANION_SESSION_SECRET=replace-with-at-least-32-random-characters
# COMPANION_ALLOWED_ORIGINS=https://game.example.com

# Optional request throttling.
# COMPANION_RATE_LIMIT=8
# COMPANION_RATE_WINDOW_MS=60000

# Local visual/test runs only. Never enable this in production.
# COMPANION_PROVIDER=deterministic
# COMPANION_ALLOW_TEST_PROVIDER=true
