# Companion API. Export these values in your shell before npm run dev:all.
COMPANION_SESSION_SECRET=replace-with-at-least-32-random-characters
COMPANION_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
COMPANION_API_KEY=replace-with-your-server-only-provider-key
COMPANION_MODEL=replace-with-an-openai-compatible-model-name
COMPANION_BASE_URL=https://api.openai.com/v1
COMPANION_TIMEOUT_MS=12000
COMPANION_PORT=8787

# Local visual/test runs only. Never enable this in production.
# COMPANION_PROVIDER=deterministic
# COMPANION_ALLOW_TEST_PROVIDER=true
